        {
          "anchor": "Changelog",
          "href": "https://areawp.com/changelog",
          "icon": "list"
        },
        {
          "anchor": "Roadmap",
          "href": "https://areawp.com/roadmap",
          "icon": "lightbulb"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
